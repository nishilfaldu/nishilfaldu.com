# Sediment: optional override for the download CTA.
# Leave unset to use the default App Store URL.
NEXT_PUBLIC_SEDIMENT_DOWNLOAD_URL=

# Cooking (WIP previews) — set on Vercel / .env.local, never commit real values.
# Access = COOKING_REPOS in lib/cooking/repos.ts ∩ fine-grained GITHUB_TOKEN.
# Preview URLs come from GitHub Deployments (no Vercel API).
GITHUB_TOKEN=

# Cloud agent launcher (owner-only bottom-right “agent” control).
# CURSOR_API_KEY — Cursor Dashboard → API Keys (server-only).
# AGENT_ACCESS_SECRET — unlock code. Visit once:
#   /api/agent/unlock?code=AGENT_ACCESS_SECRET
# That sets a 30-day httpOnly cookie; the button only mounts when present.
CURSOR_API_KEY=
AGENT_ACCESS_SECRET=
