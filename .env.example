# Copy to .env.local and fill in. Never commit real values.
# Same names as the Vercel project → Settings → Environment Variables.

# Cooking API — GitHub open PRs + deployments
GITHUB_TOKEN=

# Cooking API — Vercel preview lookups (optional; GitHub Preview deploys still work)
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Sediment download gate (public; override production Convex URL if needed)
NEXT_PUBLIC_SEDIMENT_DOWNLOAD_URL=
