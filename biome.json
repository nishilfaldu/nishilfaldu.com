{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!node_modules",
      "!.next",
      "!.claude",
      "!dist",
      "!build",
      "!**/theme.generated.css",
      "!components/tinkerletter/shoe-guide/init-shoe-guide.js",
      "!components/tinkerletter/shoe-guide/shoe-guide-body.ts",
      "!components/tinkerletter/shoe-guide/shoe-guide.css",
      "!components/tinkerletter/shoe-guide/labs"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noUnknownAtRules": "off"
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
